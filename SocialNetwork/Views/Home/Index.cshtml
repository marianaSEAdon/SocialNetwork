@using SocialNetwork.Core.Domain.Base.Enums
@model List<PostViewModel>

@{
    ViewData["Title"] = "Post";
}

<div class="container">
    <div class="d-flex justify-content-center align-items-center mb-4">
        <h2 class="d-flex align-items-center gap-2">
            My Feed
            <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#000000">
                <path d="M449-539q21 0 35.5-14.5T499-589q0-21-14.5-35.5T449-639q-21 0-35.5 14.5T399-589q0 21 14.5 35.5T449-539ZM822-80q-42 0-113-35t-152-95q-19 5-38.5 7.5T479-200q-117 0-198-81t-81-198q0-20 3-40t8-39q-59-81-94.5-151.5T81-822q0-27 15-42.5t41-15.5q26 0 67.5 18T319-801q-21 11-39 23t-35 26q-19-11-37-19t-38-17q18 38 38.5 74t43.5 71q38-54 97-85t130-31q117 0 198.5 81.5T759-479q0 71-31.5 130T642-252q35 23 71.5 44t74.5 38q-8-19-16.5-37T752-244q15-17 27-36t22-39q46 78 62.5 116.5T880-138q0 29-16 43.5T822-80ZM549-359q17 0 28.5-11.5T589-399q0-17-11.5-28.5T549-439q-17 0-28.5 11.5T509-399q0 17 11.5 28.5T549-359Zm50-140q13 0 21.5-8.5T629-529q0-13-8.5-21.5T599-559q-13 0-21.5 8.5T569-529q0 13 8.5 21.5T599-499ZM468-281q-51-44-98-91t-90-98q2 38 17 71.5t41 59.5q26 26 59 41t71 17Zm103-21q48-25 78-72.5T679-480q0-83-58.5-141T479-679q-58 0-105 30t-72 78q57 76 125 144t144 125Zm-197-73Zm117-116Z" />
            </svg>
        </h2>
    </div>
</div>

<div class="d-flex flex-column align-items-center">

    
<div class="row mb-4">
    <div class="col">
        <a asp-controller="Home" asp-action="Create"class="btn w-15 me-1"
           style="border: 1px solid #7952b3; color: #7952b3; background-color: transparent;"
           onmouseover="this.style.backgroundColor='#7952b3'; this.style.color='white';"
           onmouseout="this.style.backgroundColor='transparent'; this.style.color='#7952b3';">
            Create new post
        </a>
    </div>
</div>
 

    @if (Model == null || Model.Count == 0)
    {

        <div class="alert alert-info mt-4">
            Hello @User.FindFirstValue(ClaimTypes.Name), You don't have any posts yet.
        </div>
    }
    else
    {
        @foreach (var post in Model.OrderByDescending(p => p.CreatedAt))
        {
            <div class="col-12 col-md-8 col-lg-6 mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="comment mb-2 p-2" style="background-color: #f8f9fa; border-radius: 5px;">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(post.ProfileImage))
                                    {
                                        <img src="@Url.Content("~/" + post.ProfileImage)"
                                             class="rounded-circle"
                                             width="40"
                                             height="40"
                                             style="object-fit: cover;" />
                                    }
                                    <strong style="color: #7952b3;">
                                        @post.Username
                                    </strong>

                                </div>
                                
                                <div class="position-relative">
                                    <button type="button"
                                            class="btn p-0 menu-btn"
                                            style="background:none; border:none;"
                                            data-post-id="@post.Id"
                                            id="menuBtn-@post.Id">
                                        <i class="bi bi-three-dots"></i>
                                    </button>
                                    <div class="post-menu shadow-sm rounded-4 bg-white p-2"
                                         data-post-id="@post.Id"
                                         style="
                                                display:none;
                                                position:absolute;
                                                right:0;
                                                top:35px;
                                                width:180px;
                                                z-index:1000;">

                                        <div class="modify-item d-flex align-items-center gap-3 p-2 rounded-4 bg-light mb-2">

                                            <a asp-controller="Home"
                                               asp-action="Edit"
                                               asp-route-id="@post.Id"
                                               class="text-decoration-none text-dark">

                                                <i class="bi bi-pencil"></i>
                                                Edit Post

                                            </a>
                                        </div>

                                        <div class="modify-item d-flex align-items-center gap-3 p-2 rounded-4 bg-light">
                                            <button type="button"
                                                    class="btn p-0 text-decoration-none text-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#Modal-@post.Id">
                                                <i class="bi bi-trash3-fill"></i>
                                                Delete Post
                                            </button>

                                        </div>
                                        
                                    </div>

                                </div>

                                <!-- Modal -->
                                <div class="modal fade" id="Modal-@post.Id" tabindex="-1" aria-labelledby="modalLabel-@post.Id" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="modalLabel-@post.Id">Delete Post</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                Are you sure you want to delete this post?
                                                This action cannot be undone.
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                <form asp-controller="Home" asp-action="Delete" method="post">
                                                    <input type="hidden" name="id"
                                                           value="@post.Id"/>
                                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                           
                        </div>
                        <p class="card-text">@post.Text</p>
                        @if (!string.IsNullOrEmpty(post.Imagen))
                        {
                            <img src="@Url.Content("~/" + post.Imagen)" class="img-fluid rounded w-100" style="max-height: 600px; object-fit: cover;" alt="ups" />
                        }
                        @if (!string.IsNullOrEmpty(post.Video))
                        {
                            <div class="youtube-container ratio ratio-16x9 mb-3">
                                <iframe src="@post.Video"
                                        frameborder="0"
                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                        allowfullscreen></iframe>
                            </div>
                        }
                        <div class="mt-2">
                            <small class="text-muted">Create at: @post.CreatedAt.ToString("g")</small>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <form asp-controller="Home" asp-action="Reaction">
                                <div>
                                    @if (post.Reactions.Any(u => u.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier) && u.ReactionType == (int)ReactionType.LIKE))
                                    {
                                        <small class="text-muted">I Like</small>
                                    }
                                    else
                                    {
                                        <input type="hidden" name="PostId" value="@post.Id" />
                                        <input type="hidden" name="type" value="@( (int)ReactionType.LIKE )" />
                                        <button type="submit" class="text-decoration-none" style="color: #7952b3; border: none; background: none;">
                                            <i class="bi bi-hand-thumbs-up"></i>
                                        </button>
                                    }
                                    <a>@post.Reactions?.Count(a => a.ReactionType == (int)ReactionType.LIKE)</a>
                                </div>
                            </form>
                            <form asp-controller="Home" asp-action="Reaction">
                                @if (post.Reactions.Any(u => u.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier) && u.ReactionType == (int)ReactionType.DISLIKE))
                                {
                                    <small class="text-muted">I Dislike</small>
                                }
                                else
                                {
                                    <input type="hidden" name="PostId" value="@post.Id" />
                                    <input type="hidden" name="type" value="@( (int)ReactionType.DISLIKE )" />
                                    <button type="submit" style="color: #7952b3; border: none; background: none;">
                                        <i class="bi bi-hand-thumbs-down"></i>
                                    </button>
                                }
                                <a>@post.Reactions?.Count(a => a.ReactionType == (int)ReactionType.DISLIKE)</a>
                            </form>
                            <div class="d-flex align-items-center gap-2 comment-btn" data-post-id="@post.Id"
                                 style="cursor:pointer;">
                                <button type="button"
                                        class="btn p-0"
                                        style="color: #7952b3; background:none; border:none;">
                                    <i class="bi bi-chat-dots"></i>
                                </button>
                                <a>@post.Comments?.Count()</a>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="comments-section mb-2" data-post-id="@post.Id"
                                 style="max-height: 200px; overflow-y: auto; display:none;">

                                @foreach (var comment in post.Comments.Where(c => c.RepliedCommentId == null)
                                                        .OrderBy(c => c.CreatedAt).Take(5))
                                {
                                    <div class="d-flex flex-start mb-4">
                                        @if (!string.IsNullOrEmpty(comment.ProfileImage))
                                        {
                                            <img src="@Url.Content("~/" + comment.ProfileImage)"
                                                 class="rounded-circle shadow-sm me-2"
                                                 width="40"
                                                 height="40"
                                                 style="object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <img src="https://via.placeholder.com/40"
                                                 class="rounded-circle shadow-sm me-2"
                                                 width="40"
                                                 height="40" />
                                        }

                                        <div class="flex-grow-1 flex-shrink-1">

                                            <div class="bg-light p-3 rounded-4">

                                                <div class="d-flex justify-content-between align-items-center mb-1">

                                                    <p class="mb-0 fw-bold" style="color: #7952b3;">
                                                        @comment.Username
                                                        <span class="text-muted small fw-normal">
                                                            • @comment.CreatedAt.ToString("g")
                                                        </span>
                                                    </p>

                                                    <button class="btn btn-sm reply-btn p-0"
                                                            style="color: #7952b3; background:none; border:none;"
                                                            data-comment-id="@comment.Id">

                                                        <i class="bi bi-reply"></i>
                                                        <span class="small">Reply</span>
                                                    </button>
                                                </div>
                                                <p class="mb-0 text-dark">
                                                    @comment.Text
                                                </p>
                                            </div>

                                            <!-- Reply Form -->
                                            <div class="reply-form-container mt-2 ms-2"
                                                 data-comment-id="@comment.Id"
                                                 style="display: none;">

                                                <form asp-controller="Comment"
                                                      asp-action="AddComment"
                                                      method="post">

                                                    <input type="hidden" name="PostId" value="@post.Id" />
                                                    <input type="hidden" name="RepliedCommentId" value="@comment.Id" />

                                                    <div class="input-group">

                                                        <textarea name="Text"
                                                      class="form-control"
                                                      rows="1"
                                                      placeholder="Write a reply..."
                                                      style="resize: none;"></textarea>

                                                        <button type="submit"
                                                                class="btn"
                                                                style="background-color: #7952b3; color:white;">

                                                            <i class="bi bi-send"></i>

                                                        </button>

                                                    </div>

                                                </form>
                                                
                                            </div>

                                            <!-- Replies -->
                                            @if (comment.Replies != null && comment.Replies.Any())
                                            {
                                                <div class="mt-3 ms-4 border-start ps-5">

                                                    @foreach (var reply in comment.Replies.OrderBy(r => r.CreatedAt))
                                                    {
                                                        <div class="d-flex flex-start mb-3">

                                                            @if (!string.IsNullOrEmpty(reply.ProfileImage))
                                                            {
                                                                <img src="@Url.Content("~/" + reply.ProfileImage)"
                                                                     class="rounded-circle shadow-sm me-2"
                                                                     width="35"
                                                                     height="35"
                                                                     style="object-fit: cover;" />
                                                            }

                                                            <div class="flex-grow-1">

                                                                <div class="bg-body-tertiary p-2 rounded-4">

                                                                    <div class="d-flex justify-content-between align-items-center">

                                                                        <p class="mb-0 fw-semibold">
                                                                            @reply.Username
                                                                            <span class="text-muted small fw-normal">
                                                                                • @reply.CreatedAt.ToString("g")
                                                                            </span>
                                                                        </p>

                                                                    </div>

                                                                    <p class="small mb-0 mt-1">
                                                                        @reply.Text
                                                                    </p>

                                                                </div>

                                                            </div>

                                                        </div>
                                                    }

                                                </div>
                                            }

                                        </div>

                                    </div>
                                }

                                @if (post.Comments.Count() >= 2)
                                {
                                    <div class="p-1.5">
                                        <a>
                                            <small class="text-muted">Show all comments</small>
                                        </a>
                                    </div>
                                }
                            </div>

                            <form asp-controller="Comment" asp-action="AddComment">
                                <input type="hidden" name="PostId" value="@post.Id" />
                                <div class="input-group">
                                    <textarea name="Text"
                                      class="form-control"
                                      rows="1"
                                      placeholder="Write a comment..."
                                      style="border-color: #7952b3; resize: none;"></textarea>
                                    <button type="submit"
                                            class="btn"
                                            style="background-color: #7952b3; color: white;"
                                            onmouseover="this.style.backgroundColor='#5e3d8a';"
                                            onmouseout="this.style.backgroundColor='#7952b3';">
                                        <i class="bi bi-send"></i>
                                    </button>
                                </div>
                            </form>

                        </div>

                        
                    </div>
                </div>

            </div>
        }

    }

</div>



<script>


    function toggleComments() {
        document.querySelectorAll('.comment-btn').forEach(button => {

            button.addEventListener('click', function () {

                const postId = this.getAttribute('data-post-id');

                const commentsSection = document.querySelector(
                    `.comments-section[data-post-id="${postId}"]`
                );

                if (commentsSection.style.display === 'none') {
                    commentsSection.style.display = 'block';
                }
                else {
                    commentsSection.style.display = 'none';
                }

            });

        });
    }

    function toggleReplyForms() {
        document.querySelectorAll('.reply-btn').forEach(button => {

            button.addEventListener('click', function () {

                const commentId = this.getAttribute('data-comment-id');

                const formContainer = document.querySelector(
                    `.reply-form-container[data-comment-id="${commentId}"]`
                );

                document.querySelectorAll('.reply-form-container')
                    .forEach(container => {
                        container.style.display = 'none';
                    });

                formContainer.style.display = 'block';

            });

        });
    }

    function togglePostMenus() {
        document.querySelectorAll('.menu-btn').forEach(button => {
            button.addEventListener('click', function () {

            const postId = this.getAttribute('data-post-id');

            const currentMenu = document.querySelector(
                `.post-menu[data-post-id="${postId}"]`
            );

            // cerrar todos
            document.querySelectorAll('.post-menu').forEach(menu => {

                if(menu !== currentMenu){
                    menu.style.display = 'none';
                }

            });

            // toggle
            if(currentMenu.style.display === 'block'){
                currentMenu.style.display = 'none';
            }
            else{
                currentMenu.style.display = 'block';
            }

        });

    });

    }

    document.addEventListener('DOMContentLoaded', function (){
        toggleComments();
        toggleReplyForms();
        togglePostMenus();

    });

</script>