@model RegisterUserViewModel
@{
    ViewData["Title"] = "Register User";
    Layout = "_LayoutAnonymous";
}


<div class="justify-content-center" style="margin-top: 3rem;">
    <div class="col-12 col-md-6 offset-md-3">
        <div class="card shadow rounded-4 border-0">
            <div class="card-header text-light text-center rounded-top-4" style="background: linear-gradient(90deg, #7952b3, #6f42c1);">
                <h4 class="m-0">New User</h4>
                <small>Please register to continue</small>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.HasError != null && ViewBag.HasError)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @foreach (var error in ViewBag.Errors)
                        {
                            <p class="text-danger">@error</p>
                        }
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                    </div>
                }
                <form asp-controller="Login" asp-action="Register" method="POST" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label">Name:</label>
                        <input class="form-control" asp-for="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label">LastName:</label>
                        <input class="form-control" asp-for="LastName" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Phone:</label>
                        <input class="form-control" asp-for="Phone" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email:</label>
                        <input class="form-control" asp-for="Email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">UserName:</label>
                        <input class="form-control" asp-for="UserName" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password:</label>
                        <input class="form-control" asp-for="Password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm password:</label>
                        <input class="form-control" asp-for="ConfirmPassword" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProfileImageFile" class="form-label">Profile Image:</label>
                        <input class="form-control" asp-for="ProfileImageFile" />
                        <span asp-validation-for="ProfileImageFile" class="text-danger"></span>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-outline-primary float-end"> Save</button>
                        <a asp-controller="Login" asp-action="Index" class="btn btn-outline-warning float-end me-2"> Back to login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>