@model UpdateUserViewModel
@{
    ViewData["Title"] = "Update User";
}

<div class="justify-content-center" style="margin-top: 3rem;">
    <div class="col-12 col-md-6 offset-md-3">
        <div class="card shadow rounded-4 border-0">
            <div class="card-header text-light text-center rounded-top-4" style="background: hsla(264, 39%, 51%, 1);
             background: linear-gradient(90deg, hsla(264, 39%, 51%, 1) 0%, hsla(96, 22%, 5%, 1) 100%);
             background: -moz-linear-gradient(90deg, hsla(264, 39%, 51%, 1) 0%, hsla(96, 22%, 5%, 1) 100%);
             background: -webkit-linear-gradient(90deg, hsla(264, 39%, 51%, 1) 0%, hsla(96, 22%, 5%, 1) 100%);">
                <h4 class="m-0 mb-2">Edit User</h4>
                <div>
                    <img src="@Url.Content($"~/{Model.ProfileImage}")" class="rounded-circle mb-3" alt="@Model.FirstName" width="100" height="100" />
                </div>
                <small>Hello @Model.FirstName @Model.LastName!</small>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.HasError != null && ViewBag.HasError)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @foreach (var error in ViewBag.Errors)
                        {
                            <p class="text-danger">@error</p>
                        }
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="close"></button>
                    </div>
                }
                <form asp-controller="User" asp-action="Edit" method="POST" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label">Name:</label>
                        <input class="form-control" asp-for="FirstName" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label">LastName:</label>
                        <input class="form-control" asp-for="LastName" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Phone:</label>
                        <input class="form-control" asp-for="Phone" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email:</label>
                        <input class="form-control" asp-for="Email" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">UserName:</label>
                        <input class="form-control" asp-for="UserName" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password:</label>
                        <input class="form-control" asp-for="Password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm password:</label>
                        <input class="form-control" asp-for="ConfirmPassword" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProfileImageFile" class="form-label">Profile Image:</label>
                        <input class="form-control" asp-for="ProfileImageFile" />
                        <span asp-validation-for="ProfileImageFile" class="text-danger"></span>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-outline-primary float-end"><i class="bi bi-floppy2"></i> Save</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-warning float-end me-2"><i class="bi bi-arrow-left-short"></i> Back to home</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>